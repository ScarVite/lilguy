# Discord Bot Token — from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# Spotify API Credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Tidal API Credentials (https://developer.tidal.com)
TIDAL_CLIENT_ID=your_tidal_client_id_here
TIDAL_CLIENT_SECRET=your_tidal_client_secret_here
# Optional: defaults to US. Use an ISO 3166-1 alpha-2 country code.
TIDAL_COUNTRY_CODE=US

# Sentry Error Tracking (https://sentry.io) - Optional, only used in production
SENTRY_DSN=

# Environment (development or production)
NODE_ENV=development
